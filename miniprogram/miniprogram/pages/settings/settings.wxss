.page {
  height: 100vh;
  overflow: hidden;
}

.settings-scroll {
  height: 100%;
}

.section {
  color: var(--on-sv);
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  margin: 34rpx 0 14rpx;
}

.theme-row {
  display: flex;
}

.theme-btn {
  flex: 1;
  text-align: center;
  background: var(--surface-c);
  color: var(--on-sv);
  font-size: 24rpx;
  border-radius: 20rpx;
  padding: 16rpx 0;
  margin-right: 14rpx;
}

.theme-row .theme-btn:last-child {
  margin-right: 0;
}

.theme-btn.active {
  background: var(--primary-c);
  color: var(--on-pc);
}

.row-select {
  display: flex;
  align-items: center;
  background: var(--surface-c);
  border-radius: 20rpx;
  padding: 20rpx 26rpx;
}

.row-select-text {
  flex: 1;
  color: var(--on-surface);
  font-size: 28rpx;
}

.row-select-arrow {
  color: var(--on-sv);
  font-size: 24rpx;
}

.row-between {
  display: flex;
  align-items: center;
}

.sync-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.sync-title {
  color: var(--on-surface);
  font-size: 27rpx;
  font-weight: 500;
}

.sync-desc {
  color: var(--on-sv);
  font-size: 20rpx;
  margin-top: 4rpx;
}

.settings-search {
  background: var(--surface-c);
  border-radius: 18rpx;
  padding: 18rpx 26rpx;
  font-size: 27rpx;
  color: var(--on-surface);
  margin-bottom: 14rpx;
}

.search-ph {
  color: var(--on-sv);
}

.cur-row {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.cur-code {
  color: var(--on-surface);
  font-size: 27rpx;
  font-weight: 500;
}

.cur-name {
  flex: 1;
  color: var(--on-sv);
  font-size: 21rpx;
  margin-left: 14rpx;
}

.footer {
  text-align: center;
  color: var(--on-sv);
  font-size: 20rpx;
  opacity: 0.7;
  margin: 40rpx 0 20rpx;
}
